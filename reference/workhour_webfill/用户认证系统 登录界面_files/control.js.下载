/**账号认证面板**/
function web_panel(cookie) {
	var showAll = GetQueryString('showAll')
  // var authparam = getAuthParam() || { sms_bind: false, webchat_bind: false }
  var authparam = getAuthParam() || {}
	var sms_bind = authparam.sms_bind
	var webchat_bind = authparam.webchat_bind
  if (sms_bind || webchat_bind || showAll) {
		$("#quick_auth_panel").show();
    if ((sms_bind && webchat_bind) || showAll) {
      if (document.getElementById('quick_auth_tab3')) {
        showActiveTab('#quick_auth_tab3');
        currentSelectedPanelWithInput = '';
      } else {
        showActiveTab('#quick_auth_tab2');
        currentSelectedPanelWithInput = 'quick_sms';
      }
      $('.ant-tabs-nav .ant-tabs-tab').css('width', null);
		}
    if (sms_bind && !webchat_bind) {
