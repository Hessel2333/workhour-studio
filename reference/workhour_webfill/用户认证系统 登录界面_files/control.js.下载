/**隐藏所有面板**/
function hideAll() {
	// $('#login_panel').children('li').each(function () {
	// 	$(this).hide();
	// });

// $('#login_type').show();
// $('.icon').each(function () {
// 	$(this).show();
// });

	$('[placeholder]').focus(function () {
		var input = $(this);
		if (input.val() == input.attr('placeholder')) {
			input.val('');
			input.removeClass('placeholder');
		}
	}).blur(function () {
		var input = $(this);
		if (input.val() == '' || input.val() == input.attr('placeholder')) {
			input.addClass('placeholder');
			// input.val(input.attr('placeholder'));
		}
	}).blur().parents('form').submit(function () {
		$(this).find('[placeholder]').each(function () {
			var input = $(this);
			if (input.val() == input.attr('placeholder')) {
				input.val('');
			}
		})
	});

	$("input[name=oldPwdLabel]").focus(function () {
		$("input[name=oldPwdLabel]").hide();
		$("input[name=oldPwd]").show().focus();
	});
	$("input[name=oldPwd]").blur(function () {
		if ($(this).val() == "") {
			$("input[name=oldPwdLabel]").show();
			$("input[name=oldPwd]").hide();
		}
	})
	$("input[name=newPwdLabel]").focus(function () {
		$("input[name=newPwdLabel]").hide();
		$("input[name=newPwd]").show().focus();
	});
	$("input[name=newPwd]").blur(function () {
		if ($(this).val() == "") {
			$("input[name=newPwdLabel]").show();
			$("input[name=newPwd]").hide();
		}
	})
	$("input[name=confirmPwdLabel]").focus(function () {
		$("input[name=confirmPwdLabel]").hide();
		$("input[name=confirmPwd]").show().focus();
	});
	$("input[name=confirmPwd]").blur(function () {
		if ($(this).val() == "") {
			$("input[name=confirmPwdLabel]").show();
			$("input[name=confirmPwd]").hide();
		}
	})
	$("input[name=pwdLabel]").focus(function () {
		$("input[name=pwdLabel]").hide();
		$("input[name=pwd]").show().focus();
	});
	$("input[name=pwd]").blur(function () {
		if ($(this).val() == "") {
			$("input[name=pwdLabel]").show();
			$("input[name=pwd]").hide();
		}
	})
}
/**微信认证面板**/
function wechat_panel() {
	hideAll();
	// $(".icon-wechat-gray").hide();
	var authparam = getAuthParam();
	var isDynamic = authparam.scene_type === 'scan';
	var wx_original_id = authparam.wx_original_id;
	if (!window.wechat_name_flag && authparam.name) {
		var ori_html = $('#wx_panel_content').html();
		$('#wx_panel_content').html(ori_html + authparam.name);
		window.wechat_name_flag = true
	}
	if (api_cfg.terminal === 'pc') {
		if (isDynamic) { //微信认证
			var wx_dynamic_qrcode_panel = $('#wx_dynamic_qrcode_panel');
			if (wx_dynamic_qrcode_panel) {
				wx_dynamic_qrcode_panel.show();
				WB2.anyWhere(function (W) {
					//数据交互
					W.parseCMD("auth/getWxQRcodeImg", {
						method: 'post'
					}, {
						el: 'wx_dynamic_qrcode_img',
						parent_node: 'wx_dynamic_qrcode_div'
					}, function (sResult, bStatus) {
						if (bStatus == true) { }
					});
				});
			}
		} else { //带验证码的微信认证
			var wx_static_qrcode_panel = $('#wx_static_qrcode_panel');
			if (wx_static_qrcode_panel) {
				wx_static_qrcode_panel.show();
				if (wx_original_id) {
					$("#wx_static_qrcode_img").attr('src', '/images/qrcode/' + wx_original_id + '_qrcode.jpg');
				}
			}
		}
	} else if (api_cfg.terminal === 'mobile') {
		var wx_panel = $('#wx_panel')
		wx_panel && wx_panel.show();
	}
}

