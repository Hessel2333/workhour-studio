	}
	if (!smspassword) {
		$('#quick_smspassword').addClass('has-error');
		layer.msg(msgList.phoneCaptchaEmpty[api_cfg.language]);
		return false;
	}
	if (!checkMobile(smsusername)) {
		$('#quick_smsusername').addClass('has-error');
		layer.msg(msgList.phoneNumberError[api_cfg.language]);
		return false;
	}
	if (__WEBCONFIG.enableDisclaimer) {
		var checked = $('#quick_disclaimer_sms input').prop('checked');
		if (!checked) {
			$('#quick_disclaimer_sms span').css('color', 'red');
			$('#quick_disclaimer_sms .ant-checkbox-inner').css('border-color', 'red');
			return false;
		}
	}
	WB2.anyWhere(function (W) {
		//数据交互
		W.parseCMD("auth/smslogin", {
			method: 'post'
		}, {
			phoneNumber: smsusername,
			captcha: smspassword,
			login_type: 'pre_sms_bind'
    }, function (sResult, bStatus, CFG) {
      $("#sms_alert_warn").hide()
      if (bStatus) {
        if (sResult.is_sms_bind && !sResult.errmsg) {
          var url = window.location.origin + "/login?original_url=" + CFG.uri + "&terminal=" + api_cfg.terminal + "&page_language=" + api_cfg.language;
          window.location.href = url
        } else {
          if (sResult.errmsg) {
            errorMsg(sResult.errmsg)
          }
          if (!sResult.is_sms_bind) {
            $("#sms_alert_warn").show()
          }
        }
      } else {
        sResult && errorMsg(sResult)
      }
		});
	});
});

