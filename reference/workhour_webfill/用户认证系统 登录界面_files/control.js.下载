$('#change_password_button').click(function () {
	var username = $('#username_change').val();
	var old_password = $('#old_password').val();
	var new_password = $('#new_password').val();
	var new_password_confirm = $('#new_password_confirm').val();
	var lang = api_cfg.language || 'zh'

	try {
		if (!username) {
			$('#username_change').addClass('has-error');
			throw msgList.changepassword.inputUsername[lang]
		}
		if (!old_password) {
			$('#old_password').addClass('has-error');
			throw msgList.changepassword.inputOldPassword[lang]
		}
		if (!new_password) {
			$('#new_password').addClass('has-error');
			throw msgList.changepassword.inputNewPassword[lang]
		}
		if (!new_password_confirm) {
			$('#new_password_confirm').addClass('has-error');
			throw msgList.changepassword.confirmPassword[lang]
		}
		if (new_password !== new_password_confirm) {
			$('#new_password').addClass('has-error');
			$('#new_password_confirm').addClass('has-error');
			throw msgList.changepassword.wrongConfirmPassword[lang]
		}
		var rules = __WEBCONFIG.passwordRules || {};
		if (rules.diffName && username == new_password) {
			throw msgList.changepassword.diffName[lang]
		}
		if (rules.diffOld && old_password == new_password) {
			throw msgList.changepassword.diffOld[lang]
		}
		if (rules.minLength && new_password.length < rules.minLength) {
			throw msgList.changepassword.minLength[lang].replace('{0}', rules.minLength)
		}
		if (rules.numberAndAphabet && !(/([a-zA-Z])+/.test(new_password) && /\d+/.test(new_password))) {
			throw msgList.changepassword.numberAndAphabet[lang]
		}
		if (rules.lowerAndUppercase && !(/([a-z])+/.test(new_password) && /([A-Z])+/.test(new_password))) {
			throw msgList.changepassword.lowerAndUppercase[lang]
		}
		if (rules.specialCharacters && !/([!@#$%^&*()])+/.test(new_password)) {
			throw msgList.changepassword.specialCharacters[lang]
		}
	} catch (error) {
		layer.msg(error);
		return false;
	}

	WB2.anyWhere(function (W) {
		//数据交互
		W.parseCMD("auth/changepwd", {
			method: 'post'
		}, {
			username: $('#username_change').val(),
			password: $('#old_password').val(),
			new_password: $('#new_password').val()
		}, function (sResult, bStatus) {
			layer.msg(sResult.value)
      if (bStatus == true && sResult.fail == '104') {
        $('#changepwd_panel,#back_account').hide();
        $('#account_panel').show();
      }
		});
	});
});
