function checkMobile (v){
	var reg = /^((\+?86)|(\(\+86\)))?1\d{10}$/;
	if (!reg.test(v)) {
		return false;
	}
	return true;
}

function wxwifi_login(){
	if (!wxwifi_need_registered) {
		Wechat_GotoRedirect();
	} else if (wxwifi_registered) {
		var phone = $("#wifi_username").val();
		Wechat_GotoRedirect(phone);
	} else {
		var phone = $('#wifi_username').val();
		var code = $('#wifi_password').val();
		if (!phone) {
			$('#wifi_username').addClass('has-error');
			layer.msg(msgList.phoneNumberEmpty[api_cfg.language]);
			return false;
		}
		if (!code) {
			$('#wifi_password').addClass('has-error');
			layer.msg(msgList.phoneCaptchaEmpty[api_cfg.language]);
			return false;
		}
		if (!checkMobile(phone)) {
			$('#wifi_username').addClass('has-error');
			layer.msg(msgList.phoneNumberError[api_cfg.language]);
			return false;
		}
		WB2.anyWhere(function (W) {
			//数据交互
			W.parseCMD("auth/wxwifiCodeCheck", {
				method: 'post'
			}, {
				phoneNumber: phone,
				captcha: code
			}, function (msg) {
				var wxwifi_code_passed = msg || false;
				if (wxwifi_code_passed) {
					wxwifi_registered = true;
					Wechat_GotoRedirect(phone);
				} else {
					layer.msg(msgList.checkCaptchaError[api_cfg.language]);
				}
			});
		});
	}
}

